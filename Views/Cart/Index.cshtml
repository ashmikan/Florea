@model Floréa.Models.Cart

@{ ViewData["BodyClass"] = "cart-page"; }

<div class="container cart-container py-4">
    <h1 class="mb-4">Your Cart</h1>

    @if (!Model.CartItems.Any())
    {
        <div class="cart-panel cart-empty">
            <p class="text-muted">Your cart is empty.</p>
        </div>
    }
    else
    {
        <div class="cart-panel">
            <div class="table-responsive">
                <table class="table align-middle">
                <thead>
                    <tr>
                        <th>Flower</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CartItems)
                    {
                        <tr class="cart-item-row">
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(item.Flower.ImageUrl) ? "https://images.unsplash.com/photo-1563241527-3004b7be0ffd?auto=format&fit=crop&w=150&q=80" : item.Flower.ImageUrl)" alt="@item.Flower.Name" class="cart-item-image" />
                                    <div>
                                        <div class="cart-item-name">@item.Flower.Name</div>
                                        <div class="cart-item-desc">@item.Flower.Description</div>
                                    </div>
                                </div>
                            </td>
                            <td class="price-cell">$@item.Flower.Price</td>
                            <td>
                                <div class="quantity-control">
                                    <span class="qty-input bg-light border-0 fw-bold">@item.Quantity</span>
                                </div>
                            </td>
                            <td class="subtotal-cell">$@(item.Flower.Price * item.Quantity)</td>
                            <td>
                                <form asp-controller="Cart" asp-action="Remove" method="post">
                                    <input type="hidden" name="flowerId" value="@item.Flower.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="3" class="text-end">Total</th>
                        <th colspan="2">$@Model.CartItems.Sum(item => item.Flower.Price * item.Quantity)</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
    }
</div>