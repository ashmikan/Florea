@model Floréa.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    ViewData["BodyClass"] = "login-page register-page";
    ViewData["HideSiteChrome"] = true;
    ViewData["FullWidthPage"] = true;
}

<section class="login-page-shell">
    <div class="login-visual-panel" style="background: linear-gradient(145deg, rgba(15, 23, 42, 0.88), rgba(80, 32, 64, 0.78)), url('https://images.unsplash.com/photo-1468327768560-75b778cbb551?auto=format&fit=crop&w=1600&q=80') center/cover;">
        <div class="login-brand-badge">
            <img src="~/images/florea-logo2.png" alt="Floréa" class="login-brand-logo" />
            <span>Create your Floréa account</span>
        </div>

        <div class="login-visual-copy">
            <p class="login-eyebrow">Join the floral experience</p>
            <h1>Register once and make every bouquet, delivery, and checkout feel effortless.</h1>
            <p class="login-lead">
                Save your details, follow your orders, and enjoy a calmer way to shop for flowers and gifts.
            </p>
        </div>

        <div class="login-feature-grid">
            <article class="login-feature-card">
                <span class="login-feature-icon"><i class="bi bi-person-heart" aria-hidden="true"></i></span>
                <strong>Personalized shopping</strong>
                <p>Keep your favorite bouquets, colors, and occasions in one place.</p>
            </article>

            <article class="login-feature-card">
                <span class="login-feature-icon"><i class="bi bi-shield-check" aria-hidden="true"></i></span>
                <strong>Secure account setup</strong>
                <p>Create a modern profile with password and terms confirmation built in.</p>
            </article>
        </div>

        <div class="login-quote">
            <p>"A good register page should feel like opening a fresh arrangement: simple, elegant, and inviting."</p>
        </div>
    </div>

    <div class="login-form-panel">
        <div class="login-form-card">
            <div class="d-flex align-items-start justify-content-between gap-3 mb-4">
                <div>
                    <span class="login-form-kicker">Start here</span>
                    <h2 class="login-form-title">Create account</h2>
                    <p class="login-form-subtitle mb-0">Fill in the details below to join Floréa.</p>
                </div>
                <a asp-controller="Home" asp-action="Index" class="login-close-link" aria-label="Return to home">
                    <i class="bi bi-x-lg" aria-hidden="true"></i>
                </a>
            </div>

            <form asp-action="Index" asp-controller="Register" method="post" class="login-form" novalidate>
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label login-label"></label>
                        <input asp-for="FirstName" class="form-control login-input" placeholder="First name" autocomplete="given-name" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label login-label"></label>
                        <input asp-for="LastName" class="form-control login-input" placeholder="Last name" autocomplete="family-name" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label login-label"></label>
                    <input asp-for="Email" class="form-control login-input" placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Password" class="form-label login-label"></label>
                        <input asp-for="Password" class="form-control login-input" placeholder="Create a password" autocomplete="new-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label login-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control login-input" placeholder="Confirm password" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-3 mb-3">
                    <div class="form-check">
                        <input asp-for="AcceptTerms" class="form-check-input" />
                        <label asp-for="AcceptTerms" class="form-check-label">I agree to the terms and privacy policy</label>
                    </div>
                </div>
                <span asp-validation-for="AcceptTerms" class="text-danger small d-block mb-3"></span>

                <button type="submit" class="btn login-submit-btn w-100">
                    Create account
                </button>

                <p class="login-secondary-action mb-0">
                    Already have an account?
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                </p>
            </form>
        </div>
    </div>
</section>