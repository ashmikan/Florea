@{
    ViewData["Title"] = "About Us";
    ViewData["BodyClass"] = "about-page";
}

<div class="container py-4">
    <section class="about-hero shadow-lg">
        <h1>Our Story</h1>
        <p><i>Bringing elegance, romance, and the finest blooms to every memorable moment since 2026.</i></p>
    </section>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="about-content">
                <div class="row align-items-center">
                    <div class="col-md-6 mb-4 mb-md-0">
                        <h2>The Floréa Journey</h2>
                        <p class="lead">At Floréa Boutique, we believe that flowers are more than just gifts - they are an expression of emotion, art, and natural beauty.</p>
                        <p class="text-muted">Founded with a passion for exquisite floral arrangements, our journey began with a simple idea: to curate the freshest, most vibrant blooms and arrange them with unparalleled artistic flair. Whether it's a grand celebration or a quiet, romantic evening, our carefully selected flowers set the perfect mood.</p>
                        <p class="text-muted">We source our flowers directly from sustainable farms, ensuring that every petal that reaches you is fresh, ethically grown, and absolutely stunning.</p>
                    </div>
                    <div class="col-md-6">
                        <img src="https://images.unsplash.com/photo-1502920514313-52581002a659?auto=format&fit=crop&w=800&q=80" alt="Florist arranging flowers" class="img-fluid rounded-4 shadow-sm" />
                    </div>
                </div>

                <div class="values-grid">
                    <div class="value-card">
                        <div class="value-card-icon">
                            <i class="bi bi-flower1"></i>
                        </div>
                        <h4 class="fw-bold">Unmatched Freshness</h4>
                        <p class="text-muted mb-0">We guarantee farm-to-vase freshness, ensuring your bouquets stay vibrant and beautiful for longer.</p>
                    </div>
                    <div class="value-card">
                        <div class="value-card-icon">
                            <i class="bi bi-brush"></i>
                        </div>
                        <h4 class="fw-bold">Artistic Design</h4>
                        <p class="text-muted mb-0">Our expert florists treat every arrangement as a masterpiece, balancing colors, textures, and fragrances.</p>
                    </div>
                    <div class="value-card">
                        <div class="value-card-icon">
                            <i class="bi bi-globe-americas"></i>
                        </div>
                        <h4 class="fw-bold">Sustainable Sourcing</h4>
                        <p class="text-muted mb-0">We partner with eco-conscious growers to ensure our beautiful blooms don't cost the earth.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
