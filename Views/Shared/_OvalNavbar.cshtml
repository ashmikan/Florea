@using Floréa.Infrastructure
@using Floréa.Models
@* Oval-shaped navigation component *@
@{
  var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
  var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

  string ActiveIf(string controller, string action)
  {
    return string.Equals(currentController, controller, System.StringComparison.OrdinalIgnoreCase) &&
           string.Equals(currentAction, action, System.StringComparison.OrdinalIgnoreCase)
      ? "active"
      : string.Empty;
  }

  var cart = Context.Session.GetObject<Cart>("Cart");
  var cartCount = cart?.CartItems.Sum(item => item.Quantity) ?? 0;
}

<nav class="oval-navbar mt-3" role="navigation" aria-label="Primary oval navigation">

  <div class="oval-nav container d-flex justify-content-between align-items-center mx-auto" style="max-width: 960px;">

    <div class="navbar-logo-container me-auto">
      <a class="navbar-logo-link d-flex align-items-center gap-2 text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index" title="Floréa Home">
        <img src="~/images/florea-logo2.png" alt="Floréa Flower Shop" class="navbar-logo-image" />
      </a>
    </div>

    <div class="d-flex align-items-center gap-1">
      <a class="oval-nav-item @ActiveIf("Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index">
        <i class="bi bi-house-door oval-icon"></i>
        <span class="oval-label">Home</span>
      </a>

      <a class="oval-nav-item @ActiveIf("Flowers", "Index")" asp-area="" asp-controller="Flowers" asp-action="Index">
        <i class="bi bi-flower1 oval-icon"></i>
        <span class="oval-label">Flowers</span>
      </a>

      <a class="oval-nav-item @ActiveIf("Home", "About")" asp-area="" asp-controller="Home" asp-action="About">
        <i class="bi bi-info-circle oval-icon"></i>
        <span class="oval-label">About</span>
      </a>

      <a class="oval-nav-item @ActiveIf("Cart", "Index")" asp-area="" asp-controller="Cart" asp-action="Index">
        <div class="position-relative d-inline-flex align-items-center">
          <i class="bi bi-cart3 oval-icon"></i>
          <span class="cart-badge @(cartCount > 0 ? "" : "d-none")">@cartCount</span>
        </div>
        <span class="oval-label">Cart</span>
      </a>

      <a class="oval-nav-item @ActiveIf("Home", "Profile")" asp-area="" asp-controller="Home" asp-action="Profile">
        <i class="bi bi-person oval-icon"></i>
        <span class="oval-label">Profile</span>
      </a>

      <a class="oval-nav-item oval-nav-item--track @ActiveIf("Home", "DeliveryTracking")" asp-area="" asp-controller="Home" asp-action="DeliveryTracking">
        <i class="bi bi-truck oval-icon"></i>
        <span class="oval-label">Track</span>
      </a>
    </div>
  </div>
</nav>
